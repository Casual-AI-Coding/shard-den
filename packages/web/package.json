    "lucide-react": "^0.300.0",
    "lz-string": "^1.5.0",
    "mermaid": "^11.12.3",
    "next": "15.0.5",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
