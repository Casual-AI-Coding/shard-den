{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ShardDen",
  "identifier": "com.shardden.app",
  "build": {
    "beforeDevCommand": "npm",
    "beforeDevArgs": ["run", "dev:web"],
    "devUrl": "http://localhost:3010",
    "frontendDist": "../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "砾穴 ShardDen",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self';",
      "capabilities": [
        {
          "identifier": "default",
          "windows": ["main"],
          "permissions": [
            "path:default",
            "event:default",
            "window:default",
            "app:default",
            "image:default",
            "resources:default",
            "menu:default",
            "tray:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Copyright (c) 2026",
    "category": "DeveloperTool",
    "shortDescription": "Developer toolkit platform",
    "longDescription": "A modular developer toolkit platform with JSON extraction and more tools.",
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      }
    }
  }
}
